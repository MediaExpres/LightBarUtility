<Window x:Class="LightBarForKeyboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LightBar For Keyboard" Height="40" Width="1920"
        WindowStyle="None" ResizeMode="NoResize" 
        Background="White" Topmost="True" ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Color: White (Standard - Recommended for LCD | OLED: ~2.0W)" Click="ColorWhite_Click"/>
            <MenuItem Header="Color: Pure Green (OLED - Max Contrast | ~0.5W)" Click="ColorGreen_Click"/>
            <MenuItem Header="Color: Pure Red (OLED - Lowest Power / Night Vision | ~0.3W)" Click="ColorRed_Click"/>
            <MenuItem Header="Color: Yellow (OLED - Warm / Eye-Friendly | ~0.8W)" Click="ColorYellow_Click"/>
            <Separator/>
            <MenuItem Header="Docked Mode (Pins to bottom)" Click="MenuDocked_Click"/>
            <MenuItem Header="Floating Mode (Movable)" Click="MenuFloating_Click"/>
            <Separator/>
            <MenuItem Header="Exit" Click="MenuExit_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <TextBlock Text="LightBar For Keyboard | MediaExpres v1.0.2" 
                   Foreground="Black" FontSize="10" 
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
        <TextBlock Text="Right-click anywhere to toggle menu" 
                   Foreground="Black" FontSize="11" 
                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" />
    </Grid>
</Window>