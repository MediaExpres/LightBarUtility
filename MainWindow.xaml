<Window x:Class="LightBarForKeyboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LightBar For Keyboard" Height="40" Width="1920"
        WindowStyle="None" ResizeMode="NoResize" 
        Background="White" Topmost="True" ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Docked Mode (Pins to bottom)" Click="MenuDocked_Click"/>
            <MenuItem Header="Floating Mode (Movable)" Click="MenuFloating_Click"/>
            <Separator/>
            <MenuItem Header="Exit" Click="MenuExit_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <TextBlock Text="LightBar For Keyboard | MediaExpres v1.0.1" 
                   Foreground="#888888" FontSize="10" 
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
        <TextBlock Text="Right-click anywhere to toggle menu" 
                   Foreground="#333333" FontSize="11" 
                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" />
    </Grid>
</Window>