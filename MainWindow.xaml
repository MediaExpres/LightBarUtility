<Window x:Class="LightBarUtility.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LightBar" Height="40" Width="1920"
        WindowStyle="None" ResizeMode="NoResize" 
        Background="White" Topmost="True" ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Mod Fixat (Împinge ferestrele în sus)" Click="MenuFixat_Click"/>
            <MenuItem Header="Mod Flotant (Plutește și poate fi mutat)" Click="MenuFlotant_Click"/>
            <Separator/>
            <MenuItem Header="Închide bara (Exit)" Click="MenuClose_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
    
   <Grid>
        <TextBlock Text="Right click anywhere to toggle menu" 
                   Foreground="Gray" 
                   FontSize="11" 
                   HorizontalAlignment="Right" 
                   VerticalAlignment="Center" 
                   Margin="0,0,20,0" />
    </Grid>
</Window>